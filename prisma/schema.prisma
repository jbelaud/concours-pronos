generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
  GHOST
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  firstName     String    @default("")
  lastName      String    @default("")
  avatarSeed    String    @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  predictions          Prediction[]
  bonusPredictions     TournamentPrediction[]
  leaderboardEntries   LeaderboardEntry[]
  rankingSnapshots     RankingSnapshot[]
  contestParticipants  ContestParticipant[]
  subProfile           SubProfile?            @relation("GhostUser")
  ownedSubProfiles     SubProfile[]           @relation("OwnerUser")
}

model SubProfile {
  id          String   @id @default(cuid())
  ownerId     String
  ghostUserId String   @unique
  firstName   String
  lastName    String
  avatarSeed  String   @default(cuid())
  createdAt   DateTime @default(now())

  owner     User @relation("OwnerUser", fields: [ownerId], references: [id], onDelete: Cascade)
  ghostUser User @relation("GhostUser", fields: [ghostUserId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Invitations (lien partageable uniquement — plus d'email)
// ---------------------------------------------------------------------------

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Invite {
  id         String       @id @default(cuid())
  email      String       @unique
  firstName  String
  lastName   String
  token      String       @unique @default(cuid())
  status     InviteStatus @default(PENDING)
  expiresAt  DateTime
  sentAt     DateTime     @default(now())
  acceptedAt DateTime?
  contestId  String?

  contest Contest? @relation(fields: [contestId], references: [id])

  @@index([token])
  @@index([email])
}

// ---------------------------------------------------------------------------
// Tournament Templates
// ---------------------------------------------------------------------------

model TournamentTemplate {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  edition   String
  startDate DateTime
  endDate   DateTime
  format    String
  jsonFile  String
  createdAt DateTime @default(now())

  contests Contest[]
}

// ---------------------------------------------------------------------------
// Contest
// ---------------------------------------------------------------------------

enum ContestStatus {
  DRAFT
  REGISTRATION
  ONGOING
  FINISHED
}

model Contest {
  id                  String        @id @default(cuid())
  name                String
  status              ContestStatus @default(DRAFT)
  templateId          String
  buyIn               Float         @default(0)
  isFree              Boolean       @default(false)
  inviteToken         String?       @unique @default(cuid())
  allowPublicJoin     Boolean       @default(true)
  iban                String?
  paymentInstructions String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  template         TournamentTemplate     @relation(fields: [templateId], references: [id])
  settings         ContestSettings?
  prizepool        Prizepool?
  participants     ContestParticipant[]
  matches          Match[]
  groups           Group[]
  teams            Team[]
  predictions      Prediction[]
  bonusPredictions TournamentPrediction[]
  leaderboard      LeaderboardEntry[]
  rankingSnapshots RankingSnapshot[]
  invites          Invite[]
  scorerCandidates ScorerCandidate[]
}

model ContestParticipant {
  id        String   @id @default(cuid())
  contestId String
  userId    String
  joinedAt  DateTime @default(now())
  hasPaid   Boolean  @default(false)

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
}

// ---------------------------------------------------------------------------
// Contest Settings
// ---------------------------------------------------------------------------

// REGULAR_TIME = pronostic basé sur le score à 90' seulement
// FULL_TIME     = pronostic basé sur le score final (incl. prolongations)
enum KnockoutScoringRule {
  REGULAR_TIME
  FULL_TIME
}

model ContestSettings {
  id                   String               @id @default(cuid())
  contestId            String               @unique
  pointsCorrectResult  Int                  @default(3)
  pointsExactScore     Int                  @default(1)
  pointsWrongResult    Int                  @default(0)
  pointsWinner         Int                  @default(10)
  pointsTopScorer      Int                  @default(5)
  pointsBestAttack     Int                  @default(3)
  pointsBestDefense    Int                  @default(3)
  pointsGroupFirst     Int                  @default(2)
  pointsGroupSecond    Int                  @default(1)
  validatedGroupBonus  Json                 @default("{}")
  tieBreakerOrder      Json                 @default("[\"exactScores\",\"correctResults\",\"finalWinner\"]")
  knockoutScoringRule  KnockoutScoringRule  @default(REGULAR_TIME)

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Prizepool
// ---------------------------------------------------------------------------

model Prizepool {
  id          String   @id @default(cuid())
  contestId   String   @unique
  totalAmount Float    @default(0)
  itmCount    Int      @default(4)
  payouts     Payout[]

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
}

model Payout {
  id          String @id @default(cuid())
  prizepoolId String
  position    Int
  amount      Float

  prizepool Prizepool @relation(fields: [prizepoolId], references: [id], onDelete: Cascade)

  @@unique([prizepoolId, position])
}

// ---------------------------------------------------------------------------
// Teams
// ---------------------------------------------------------------------------

model Team {
  id        String  @id @default(cuid())
  contestId String
  name      String
  code      String
  flagEmoji String?
  group     String?
  seedIndex Int     @default(0)

  contest           Contest                @relation(fields: [contestId], references: [id], onDelete: Cascade)
  homeMatches       Match[]                @relation("HomeTeam")
  awayMatches       Match[]                @relation("AwayTeam")
  groupTeams        GroupTeam[]
  winnerPredictions TournamentPrediction[] @relation("WinnerPrediction")
  bestAttackPreds   TournamentPrediction[] @relation("BestAttackPrediction")
  bestDefensePreds  TournamentPrediction[] @relation("BestDefensePrediction")

  @@unique([contestId, code])
}

// ---------------------------------------------------------------------------
// Groups
// ---------------------------------------------------------------------------

model Group {
  id        String      @id @default(cuid())
  contestId String
  name      String
  letter    String

  contest Contest     @relation(fields: [contestId], references: [id], onDelete: Cascade)
  teams   GroupTeam[]

  @@unique([contestId, letter])
}

model GroupTeam {
  id       String @id @default(cuid())
  groupId  String
  teamId   String
  position Int?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([groupId, teamId])
}

// ---------------------------------------------------------------------------
// Matches
// ---------------------------------------------------------------------------

enum MatchPhase {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  FINAL
  THIRD_PLACE
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
}

model Match {
  id                 String      @id @default(cuid())
  contestId          String
  matchNumber        Int
  phase              MatchPhase
  kickoff            DateTime
  venue              String?
  homeTeamId         String?
  awayTeamId         String?
  homeScore          Int?
  awayScore          Int?
  regularTimeHome    Int?
  regularTimeAway    Int?
  extraTimeHome      Int?
  extraTimeAway      Int?
  status             MatchStatus @default(SCHEDULED)
  groupLetter        String?
  knockoutLabel      String?

  contest     Contest      @relation(fields: [contestId], references: [id], onDelete: Cascade)
  homeTeam    Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  predictions Prediction[]

  @@index([contestId, kickoff])
  @@index([contestId, phase])
}

// ---------------------------------------------------------------------------
// Predictions
// ---------------------------------------------------------------------------

enum PredictionStatus {
  PENDING
  CORRECT_RESULT
  EXACT_SCORE
  WRONG
}

model Prediction {
  id        String           @id @default(cuid())
  userId    String
  matchId   String
  contestId String
  homeScore Int
  awayScore Int
  points    Int              @default(0)
  status    PredictionStatus @default(PENDING)
  lockedAt  DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  match   Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([contestId, userId])
  @@index([matchId])
}

// ---------------------------------------------------------------------------
// Tournament Bonus Predictions
// ---------------------------------------------------------------------------

model TournamentPrediction {
  id                String    @id @default(cuid())
  userId            String
  contestId         String
  winnerId          String?
  topScorerId       String?
  topScorerFreeText String?
  bestAttackId      String?
  bestDefenseId     String?
  points            Int       @default(0)
  groupPoints       Int       @default(0)
  lockedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest     Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  winner      Team?   @relation("WinnerPrediction", fields: [winnerId], references: [id])
  bestAttack  Team?   @relation("BestAttackPrediction", fields: [bestAttackId], references: [id])
  bestDefense Team?   @relation("BestDefensePrediction", fields: [bestDefenseId], references: [id])

  groupPredictions GroupPrediction[]

  @@unique([userId, contestId])
}

model GroupPrediction {
  id                     String @id @default(cuid())
  tournamentPredictionId String
  groupLetter            String
  firstTeamCode          String
  secondTeamCode         String

  tournamentPrediction TournamentPrediction @relation(fields: [tournamentPredictionId], references: [id], onDelete: Cascade)

  @@unique([tournamentPredictionId, groupLetter])
}

// ---------------------------------------------------------------------------
// Top Scorer Candidates
// ---------------------------------------------------------------------------

model ScorerCandidate {
  id        String  @id @default(cuid())
  contestId String
  name      String
  teamCode  String
  isWinner  Boolean @default(false)

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
}

// ---------------------------------------------------------------------------
// Leaderboard
// ---------------------------------------------------------------------------

model LeaderboardEntry {
  id             String   @id @default(cuid())
  contestId      String
  userId         String
  rank           Int      @default(0)
  previousRank   Int?
  totalPoints    Int      @default(0)
  exactScores    Int      @default(0)
  correctResults Int      @default(0)
  bonusPoints    Int      @default(0)
  updatedAt      DateTime @updatedAt

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@index([contestId, rank])
}

// ---------------------------------------------------------------------------
// Ranking Snapshots
// ---------------------------------------------------------------------------

model RankingSnapshot {
  id          String   @id @default(cuid())
  contestId   String
  userId      String
  rank        Int
  totalPoints Int
  matchday    Int
  takenAt     DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contestId, matchday])
  @@index([contestId, userId])
}
